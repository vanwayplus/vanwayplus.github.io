---
interface Props {
    badge?: string
    url?: string
    label?: string
}
const { badge, url, label } = Astro.props
---
<a href={url} aria-label={label} class="group flex items-center justify-between gap-4 py-2.5 border-b border-black/5 dark:border-white/[0.06] last:border-b-0">
    <div class="overflow-hidden text-left whitespace-nowrap overflow-ellipsis text-black/70 dark:text-white/70 transition group-hover:text-[var(--primary)]">
        <slot></slot>
    </div>
    { badge !== undefined && badge !== null && badge !== '' &&
        <div class="text-[0.72rem] font-semibold tracking-[0.18em] text-black/35 dark:text-white/35 transition group-hover:text-[var(--primary)]">
            { badge }
        </div>
    }
</a>
