---
import ImageWrapper from "../misc/ImageWrapper.astro";
import {Icon} from "astro-icon/components";
import {profileConfig} from "../../config";

const config = profileConfig;
---
<div class="card-base">
    <a aria-label="Go to About Page" href="/about"
       class="group block relative mx-auto mt-4 lg:mx-4 lg:mt-4 mb-4
       max-w-[220px] lg:max-w-none overflow-hidden rounded-[1.1rem] active:scale-[0.985]">
        <div class="absolute transition pointer-events-none group-hover:bg-black/20 group-active:bg-black/35
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 group-hover:opacity-100 text-white text-4xl">
            </Icon>
        </div>
        <ImageWrapper src={config.avatar} alt="Profile Image of the Author" class="mx-auto lg:w-full aspect-square h-full lg:mt-0 "></ImageWrapper>
    </a>
    <div class="px-5 pb-5">
        <div class="font-semibold text-[1.45rem] text-center mb-1 text-black/85 dark:text-neutral-50 transition tracking-[-0.02em]">{config.name}</div>
        <div class="h-1 w-10 bg-[var(--primary)] mx-auto rounded-full mb-3 transition opacity-80"></div>
        <div class="text-center text-black/50 dark:text-white/50 mb-4 transition leading-7">{config.bio}</div>
        <div class="flex gap-2 mx-2 justify-center">
        {config.links.map(item =>
            <a aria-label={item.name} href={item.url} target="_blank" class="btn-regular rounded-xl h-11 w-11 active:scale-90">
                <Icon name={item.icon} size="1.5rem"></Icon>
            </a>
        )}
        </div>
    </div>
</div>
