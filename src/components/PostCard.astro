---
import path from "path";
import PostMetadata from "./PostMeta.astro";
import ImageWrapper from "./misc/ImageWrapper.astro";
import { Icon } from 'astro-icon/components';
import {i18n} from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";
import {getDir} from "../utils/url-utils";

interface Props {
    class: string;
    entry: any;
    title: string;
    url: string;
    published: Date;
    tags: string[];
    category: string;
    image: string;
    coverFit: 'cover' | 'contain';
    hideDate: boolean;
    description: string;
    words: number;
    draft: boolean;
    style: string;
}
const { entry, title, url, published, tags, category, image, coverFit, hideDate, description, style } = Astro.props;
const className = Astro.props.class;

const hasCover = image !== undefined && image !== null && image !== '';
// Wide figures/diagrams (coverFit: contain) render as a full-width top banner at
// their natural aspect ratio — shown whole, never cropped or shrunk into a slot.
const bannerMode = hasCover && coverFit === 'contain';
// Everything else uses a side thumbnail that fills its frame (best for photos).
const sideCover = hasCover && !bannerMode;

const basePath = path.join("content/posts/", getDir(entry.id));

// Cap the tags shown on the (narrow) card so the meta row stays on one line;
// the full tag list still appears on the post detail page.
const cardTags = Array.isArray(tags) ? tags.slice(0, 3) : tags;

const { remarkPluginFrontmatter } = await entry.render();
---
<article class:list={["post-card card-base w-full",
    bannerMode ? "flex flex-col" : "flex flex-col-reverse md:flex-row", className]} style={style}>

    {bannerMode &&
        <a href={url} aria-label={title} class="post-card-banner group relative block w-full overflow-hidden">
            <ImageWrapper src={image} basePath={basePath} alt={`Figure for ${title}`}
                          class="post-card-banner-img w-full"></ImageWrapper>
            <div class="absolute inset-0 z-10 transition group-hover:bg-black/[0.06] group-active:bg-black/10 pointer-events-none"></div>
        </a>
    }

    <div class="post-card-body flex flex-col justify-center grow px-6 py-6 md:px-7 md:py-7">
        <a href={url}
           class="post-card-title transition block font-bold text-[1.5rem] md:text-[1.65rem] leading-[1.12] tracking-[-0.02em] text-90
           hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
           active:text-[var(--title-active)] dark:active:text-[var(--title-active)]">
            {title}
        </a>

        <PostMetadata published={published} tags={cardTags} category={category} hideTagsForMobile={true} hideDate={hideDate} class="mt-3 mb-3.5"></PostMetadata>

        {description && <div class="post-card-desc transition text-75 text-[0.98rem] leading-7">{description}</div>}

        <div class="post-card-footer mt-4 flex items-center gap-3 text-xs tracking-[0.08em] uppercase text-30">
            <span>{remarkPluginFrontmatter.words} {i18n(I18nKey.wordsCount)}</span>
            <span class="opacity-40">/</span>
            <span>{remarkPluginFrontmatter.minutes} {i18n(I18nKey.minutesCount)}</span>
            <span class="post-card-readmore ml-auto hidden md:inline-flex items-center gap-1 text-[var(--primary)] font-semibold normal-case tracking-normal text-sm">
                Read
                <Icon name="material-symbols:arrow-forward-rounded" size={17} class="post-card-arrow-icon transition"></Icon>
            </span>
        </div>
    </div>

    {sideCover &&
        <a href={url} aria-label={title}
           class="post-card-cover group relative block shrink-0 overflow-hidden h-48 md:h-auto md:w-[15.5rem] lg:w-[17rem]">
            <ImageWrapper src={image} basePath={basePath} alt={`Cover image of ${title}`}
                          class="post-card-cover-img w-full h-full"></ImageWrapper>
            <div class="absolute inset-0 z-10 transition group-hover:bg-black/15 group-active:bg-black/25 pointer-events-none"></div>
            <div class="absolute inset-0 z-20 flex items-center justify-center opacity-0 transition group-hover:opacity-100 pointer-events-none">
                <Icon name="material-symbols:arrow-forward-rounded" class="text-white text-4xl"></Icon>
            </div>
        </a>
    }

    {!hasCover &&
        <a href={url} aria-label={title}
           class="post-card-enter hidden md:flex btn-plain shrink-0 w-14 items-center justify-center rounded-none active:scale-95">
            <Icon name="material-symbols:chevron-right-rounded" class="text-[var(--primary)] text-4xl"></Icon>
        </a>
    }
</article>

<style lang="stylus">
  .post-card
    overflow: hidden
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease
    &:hover
      transform: translateY(-2px)
  .post-card-title
    display: -webkit-box
    -webkit-line-clamp: 3
    -webkit-box-orient: vertical
    overflow: hidden
  .post-card-desc
    display: -webkit-box
    -webkit-line-clamp: 2
    -webkit-box-orient: vertical
    overflow: hidden

  // --- side thumbnail (default, fills frame — best for photos) ---
  .post-card-cover
    background: var(--btn-regular-bg)
    @media (min-width: 768px)
      min-height: 12.5rem
  .post-card-cover :global(img)
    transition: transform 0.35s ease
  .post-card:hover .post-card-cover :global(img)
    transform: scale(1.045)

  // --- full-width figure banner (coverFit: contain — wide diagrams) ---
  // White panel merges seamlessly with white-background figures; the image keeps
  // its natural aspect ratio so nothing is cropped or awkwardly shrunk.
  .post-card-banner
    background: #ffffff
    padding: 1rem
    border-bottom: 1px solid rgba(0, 0, 0, 0.07)
  .post-card-banner :global(img)
    height: auto !important
    max-height: 24rem
    object-fit: contain
  .post-card-banner :global(.post-card-banner-img > div)
    display: none

  .post-card:hover .post-card-arrow-icon
    transform: translateX(3px)
</style>
